# ===========================================
# 1C Syntax Helper MCP Server - Environment
# ===========================================
# Скопируйте этот файл в .env и настройте значения

# -------------------------------------------
# Elasticsearch Configuration
# -------------------------------------------
# Хост Elasticsearch (для Docker: elasticsearch)
ELASTICSEARCH_HOST=localhost

# Порт Elasticsearch
ELASTICSEARCH_PORT=9200

# Полный URL (приоритет над host:port)
ELASTICSEARCH_URL=http://localhost:9200

# Имя индекса
ELASTICSEARCH_INDEX=help1c_docs

# Таймаут запросов (секунды)
ELASTICSEARCH_TIMEOUT=30

# Количество повторных попыток
ELASTICSEARCH_MAX_RETRIES=3

# -------------------------------------------
# Connection Pool Settings
# -------------------------------------------
# Максимальный размер пула соединений
ELASTICSEARCH_POOL_MAXSIZE=10

# Максимум повторных попыток пула
ELASTICSEARCH_POOL_MAX_RETRIES=3

# Таймаут подключения (секунды)
ELASTICSEARCH_CONNECT_TIMEOUT=10

# Таймаут чтения (секунды)
ELASTICSEARCH_READ_TIMEOUT=30

# -------------------------------------------
# Server Configuration
# -------------------------------------------
# Хост сервера
SERVER_HOST=0.0.0.0

# Порт сервера
SERVER_PORT=8000

# Уровень логирования (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Режим отладки (true/false)
DEBUG=false

# -------------------------------------------
# Data Paths
# -------------------------------------------
# Путь к директории с .hbk файлами
HBK_DIRECTORY=data/hbk

# Путь к директории логов
LOGS_DIRECTORY=data/logs

# Путь к основному .hbk файлу (приоритет над HBK_DIRECTORY)
HBK_FILE_PATH=data/hbk/1c_documentation.hbk

# -------------------------------------------
# Performance Settings
# -------------------------------------------
# Максимум одновременных запросов
MAX_CONCURRENT_REQUESTS=8

# Размер пакета при индексации
INDEX_BATCH_SIZE=100

# Переиндексация при старте (true/false)
REINDEX_ON_STARTUP=true

# Максимум результатов поиска
SEARCH_MAX_RESULTS=50

# Таймаут поиска (секунды)
SEARCH_TIMEOUT_SECONDS=30

# -------------------------------------------
# Cache Settings
# -------------------------------------------
# Максимальный размер кэша (записей)
CACHE_MAX_SIZE=1000

# TTL кэша (секунды)
CACHE_TTL_SECONDS=300

# -------------------------------------------
# Rate Limiting
# -------------------------------------------
# Максимум запросов в минуту на IP
RATE_LIMIT_PER_MINUTE=60

# -------------------------------------------
# Security (для production)
# -------------------------------------------
# API ключ (опционально)
# API_KEY=your-secret-api-key-here

# Разрешенные CORS origins (через запятую)
# CORS_ORIGINS=http://localhost:3000,http://example.com
